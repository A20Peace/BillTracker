# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (document parsing) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (email notifications) ─────────────────────────────────────────────
RESEND_API_KEY=
# Verified "from" address, e.g. "KeepinBill <noreply@yourdomain.com>"
RESEND_FROM="KeepinBill <onboarding@resend.dev>"

# ─── Cron protection ──────────────────────────────────────────────────────────
# Random secret; Vercel Cron sends it as the Authorization bearer token.
CRON_SECRET=

# ─── Market benchmarks (admin) ────────────────────────────────────────────────
# Optional. If set, only this account can edit /settings/benchmarks.
# If left empty, any authenticated user can edit (personal/single-user setup).
BENCHMARK_ADMIN_EMAIL=

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL, used for OAuth redirects and email deep-links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
